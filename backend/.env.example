APP_BASE_URL=http://localhost:5000
SECRET_KEY=replace-with-a-long-random-secret

# Preferred: provide a full connection string
MONGO_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# Alternative to MONGO_URI:
# MONGO_USERNAME=username
# MONGO_PASSWORD=password
# MONGO_CLUSTER=cluster0.example.mongodb.net
# MONGO_OPTIONS=?retryWrites=true&w=majority&appName=Cluster0

MONGO_DATABASE_NAME=url_db
MONGO_COLLECTION_NAME=urls
CORS_ALLOWED_ORIGINS=http://localhost:3000
DEFAULT_RATE_LIMITS=200 per day,50 per hour
SHORTEN_RATE_LIMIT=10 per minute
